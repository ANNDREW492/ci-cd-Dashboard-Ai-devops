{
  "name": "ci-cd-dashboard-ai-devops",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
      "dev": "vite",
      "build": "vite build",
      "preview": "vite preview",
      "start:backend": "cd backend-api && node server.js",
      "start:frontend": "vite",
      "start:smee": "npx smee-client -u https://smee.io/UrIlzQgJBK8Fkqv0 -p 3000 -P /api/webhooks/ci-logs",
      "start:ai": "cd ai-service && .\\venv\\Scripts\\python -m uvicorn main:app --reload",
      "dev:all": "concurrently --restart-tries 3 --restart-after 2000 -c \"cyan,magenta,yellow,green\" -n \"BACKEND,FRONTEND,WEBHOOK,AI-CERBR\" \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:smee\" \"npm run start:ai\""
    },
  "dependencies": {
    "chart.js": "^4.5.1",
    "echarts": "^6.0.0",
    "vue": "^3.5.30",
    "vue-chartjs": "^5.3.3",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "vite": "^8.0.1"
  }
}
